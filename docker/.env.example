# Copy this file to .env and replace every blank secret or credential value.
# Do not commit .env.
SHADOWDROP_BOOTSTRAP_ADMIN_TOKEN=
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
SHADOWDROP_MONGO_CONNECTION_STRING=

# Keep the default for host-local access. Use 0.0.0.0 only when LAN exposure is intentional.
SHADOWDROP_BIND_ADDRESS=127.0.0.1
