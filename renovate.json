{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "addLabels": [
    "renovate"
  ],
  "major": {
    "dependencyDashboardApproval": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/MongoDbTestImages\\.cs$/"
      ],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) packageName=(?<packageName>\\S+)\\s+public const String \\w+ = \"mongo:(?<currentValue>[^\"]+)\";"
      ]
    }
  ],
  "packageRules": [
    {
      "description": "Restore old NuGet update behavior for bare versions",
      "matchManagers": [
        "nuget"
      ],
      "rangeStrategy": "bump"
    },
    {
      "description": "Allow FluentAssertions updates within v7 only",
      "matchPackageNames": [
        "FluentAssertions"
      ],
      "allowedVersions": "<8"
    },
    {
      "description": "Keep the minimum-version compatibility image on MongoDB 5.0 patches",
      "matchDepNames": [
        "mongo-5"
      ],
      "allowedVersions": "/^5\\.0\\./"
    },
    {
      "groupName": "Test SDK/MTP",
      "matchPackageNames": [
        "Microsoft.NET.Test.Sdk",
        "Microsoft.TestPlatform.TestHost",
        "Microsoft.Testing.Platform",
        "Microsoft.Testing.Extensions.CodeCoverage"
      ]
    },
    {
      "groupName": "NUnit",
      "matchPackageNames": [
        "NUnit",
        "NUnit.Analyzers",
        "NUnit3TestAdapter"
      ]
    },
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    }
  ]
}
