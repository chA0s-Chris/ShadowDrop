{
  "ShadowDrop": {
    "Metadata": {
      "LiteDbPath": "data/metadata/shadowdrop.db"
    },
    "Storage": {
      "LocalRoot": "data/storage"
    },
    "ApiExposure": {
      "EnablePublicDownloads": true,
      // EnableAdminOperations defaults to true. Exposing /api/admin/* publicly requires an upstream
      // exposure boundary or request throttling; see docs/DEPLOYMENT_HARDENING.md before deploying.
      "EnableAdminOperations": true
    },
    "Cleanup": {
      "CronExpression": "0 */2 * * *"
    },
    "Upload": {
      "MaxBytes": 4294967296
    }
  }
}
